# Copy this file to server/.env for local development.
# For the single-server production launch, copy it to:
#   /etc/agents-chat/server.env
# Then update NODE_ENV, secrets, and any host-specific values.

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
DATABASE_URL=postgres://agents_chat:agents_chat@localhost:5432/agents_chat
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me
OPERATOR_TOKEN=replace-me-operator
AUTH_EMAIL_VERIFICATION_CODE_TTL_SECONDS=600
AUTH_PASSWORD_RESET_CODE_TTL_SECONDS=900
AUTH_EMAIL_CODE_COOLDOWN_SECONDS=60
AGENT_PRESENCE_STALE_AFTER_SECONDS=180
AGENT_PRESENCE_SWEEP_INTERVAL_SECONDS=30
MAIL_DELIVERY_MODE=log
MAIL_FROM_ADDRESS=Agents Chat <no-reply@agentschat.app>
MAIL_RESEND_API_KEY=
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agents-chat-local
AGENT_CANT_SECRET=replace-me-agent-cant-secret
STT_PYTHON_BIN=/opt/agents-chat/shared/stt-venv/bin/python
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_TIMEOUT_MS=90000
STT_MAX_UPLOAD_BYTES=10485760
STT_MAX_DURATION_SECONDS=60
FFMPEG_BIN=/usr/bin/ffmpeg
STT_MODEL_DIR=/opt/agents-chat/shared/models/faster-whisper

# Single-server production notes:
# - set NODE_ENV=production
# - keep PORT=3000 behind Caddy
# - if MinIO runs on the same server, set MINIO_ENDPOINT=127.0.0.1
# - replace JWT_SECRET and OPERATOR_TOKEN with long random values
# - replace AGENT_CANT_SECRET with a long random value used by the Agent Cant SDK
# - switch MAIL_DELIVERY_MODE to resend and set MAIL_RESEND_API_KEY
# - add the DNS records required by your mail sender before enabling password reset / verification
# - tune AGENT_PRESENCE_STALE_AFTER_SECONDS only if you need a looser or stricter online timeout
# - keep STT_PYTHON_BIN, STT_MODEL_DIR, and FFMPEG_BIN pointed at the local server runtime
