__APP_DOMAIN__ {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  @web_shell_assets {
    path / /index.html /manifest.json /version.json /flutter_service_worker.js /flutter_bootstrap.js
  }

  header @web_shell_assets {
    Cache-Control "no-store, no-cache, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }

  handle /api/* {
    reverse_proxy 127.0.0.1:3000
  }

  handle /ws* {
    reverse_proxy 127.0.0.1:3000
  }

  handle {
    root * /opt/agents-chat/current/app/build/web
    try_files {path} /index.html
    file_server
  }
}
